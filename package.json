{
  "name": "mrscrapper",
  "version": "1.0.0",
  "description": "Naver SmartStore scraper API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "npm run build",
    "test:unit": "node --test --import tsx \"tests/unit/**/*.test.ts\"",
    "test:integration": "node --test --import tsx \"tests/integration/**/*.test.ts\"",
    "benchmark:baseline": "tsx scripts/perf/baseline.ts",
    "benchmark:corpus": "tsx scripts/perf/corpus.ts",
    "benchmark:soak": "tsx scripts/perf/soak.ts",
    "submission:capture-anti": "tsx scripts/submission/capture-anti-detection.ts",
    "submission:sync-gates": "tsx scripts/submission/sync-gate-status.ts",
    "submission:check": "tsx scripts/submission/check.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "fastify": "^5.10.0",
    "playwright-core": "^1.61.1",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
