# API server
HOST=127.0.0.1
PORT=3000

# CDP sidecar (Docker Chromium Sidecar)
CHROME_TOKEN=my-super-secret-token-123
CDP_URL=ws://chromium:3000?token=my-super-secret-token-123
CDP_CONNECT_RETRIES=2
CDP_RETRY_DELAY_MS=250

# Capture timings (milliseconds)
NAVIGATION_TIMEOUT_MS=8000
CAPTURE_GRACE_MS=4000
BLOCKED_RESOURCE_TYPES=image,font,media
REQUEST_JITTER_MIN_MS=150
REQUEST_JITTER_MAX_MS=900

# Anti-detection telemetry
IP_SAMPLING_ENABLED=false
IP_SAMPLE_MIN_INTERVAL_MS=60000

# Optional custom fingerprint profiles JSON array.
# If unset, built-in rotating profiles are used.
# FINGERPRINT_PROFILES_JSON=[{"id":"profile-1","userAgent":"...","locale":"ko-KR","timezoneId":"Asia/Seoul","viewport":{"width":1366,"height":768},"colorScheme":"light"}]

# Short-lived successful response cache
CACHE_TTL_MS=60000

# Request orchestration
WORKER_PAGES=2
MAX_QUEUE_DEPTH=50
QUEUE_WAIT_TIMEOUT_MS=4000
GLOBAL_REQUEST_TIMEOUT_MS=12000
MAX_ATTEMPTS=2

# Proxy adapter (optional for now)
# Set these only when your local proxy adapter is running.
# Example:
# PROXY_SERVER=http://127.0.0.1:8899
# PROXY_USERNAME=td-customer-...
# PROXY_PASSWORD=...

# Optional authenticated session state.
# Log in manually once, save the browser storage state, and point the scraper at it.
# NAVER_STORAGE_STATE_PATH=artifacts/naver-auth/storage-state.json
